# ------------------------------------------------------------------
# Copy me to .env.local and fill in the real values. Never commit that file.
# In Vercel, these same names go under Project Settings > Environment Variables.
# ------------------------------------------------------------------

# --- NextAuth ---
# Generate with: openssl rand -base64 32  (or: npx auth secret)
AUTH_SECRET=

# Only needed in production (Vercel sets it for you locally it's inferred)
# AUTH_URL=https://your-app.vercel.app

# From Google Cloud Console > Credentials > OAuth client
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Supabase ---
# Project Settings > API. The service_role key is the skeleton key —
# it bypasses RLS entirely. Server-side only. Never expose it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Authorization ---
# The entire access model: comma-separated, no spaces.
# Must match the emails seeded into the authors table.
ALLOWED_EMAILS=denard@example.com,airhyl@example.com
